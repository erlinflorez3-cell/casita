<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape
            android:shape="ring"
            android:useLevel="false"
            android:type="sweep">
            <solid android:color="@color/onboard_sdk_darkGray"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate
            android:fromDegrees="0"
            android:toDegrees="720"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape
                android:shape="ring"
                android:angle="0"
                android:type="sweep">
                <solid android:color="@color/onboard_sdk_black"/>
            </shape>
        </rotate>
    </item>
</layer-list>
