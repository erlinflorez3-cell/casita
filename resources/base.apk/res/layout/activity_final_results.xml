<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/constraintLayoutBackground"
    style="@style/constraintLayoutBackground">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayoutSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/constraintLayoutSurface">
        <ImageView
            android:id="@+id/imageViewBack"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/buttonBack"/>
        <ImageView
            android:id="@+id/imageViewClose"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toEndOf="@+id/constraintLayoutSurface"
            app:layout_constraintTop_toTopOf="@+id/constraintLayoutSurface"
            style="@style/buttonClose"/>
        <ImageView
            android:id="@+id/imageViewEnterpriseLogo"
            android:src="@drawable/ic_enterprise_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/enterpriseLogo"/>
        <com.ticnow.sdk.idnowonboarding.steps.stephandler.views.CircleImageView
            android:id="@+id/faceView"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            android:layout_centerInParent="true"
            app:civ_border_color="@color/colorPrimary"
            app:civ_border_width="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageViewEnterpriseLogo"/>
        <ScrollView
            app:layout_constraintBottom_toTopOf="@+id/buttonContinue"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/faceView"
            style="@style/scrollViewContainer">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/layoutScrollViewContainer"
                style="@style/layoutScrollViewContainer"/>
        </ScrollView>
        <Button
            android:id="@+id/buttonContinue"
            android:layout_marginBottom="10dp"
            android:text="Continuar"
            app:layout_constraintBottom_toBottomOf="@+id/constraintLayoutSurface"
            app:layout_constraintEnd_toEndOf="@+id/constraintLayoutSurface"
            app:layout_constraintStart_toStartOf="@+id/constraintLayoutSurface"
            style="@style/buttonContinueEnabled"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutInfoUsuario"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.cardview.widget.CardView
            android:id="@+id/imagen_usuarioCV"
            android:layout_width="@dimen/detalleUsuarioCardViewSize"
            android:layout_height="@dimen/detalleUsuarioCardViewSize"
            app:cardCornerRadius="@dimen/detalleUsuarioCardViewCorner"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/avatar"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>
        <com.ticnow.sdk.idnowonboarding.steps.stephandler.views.TicnowMessageBox
            android:layout_width="wrap_content"
            android:layout_height="@dimen/altoTextoDetalleUsuarioCardView"
            android:layout_marginTop="@dimen/margenTextoDetalleUsuarioCardView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imagen_usuarioCV"
            app:message="Nombre: Nombre Segundo\10Apellidos: Apellido1 Apellido2\10Edad:25 años\10Dirección: Calle falsa 1234567890\10Distrito: Distrito X\10Otra Informacion relevante"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
