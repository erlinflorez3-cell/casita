<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/ivLogoTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:adjustViewBounds="true"
        android:layout_marginStart="@dimen/onboard_sdk_logo_top_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_logo_top_margins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/onboard_sdk_logo_top"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/topHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/onboard_sdk_recognition_result_title"
        android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivLogoTop"
        style="@style/onboard_sdk_Headline2"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerMatchingImages"
        android:visibility="invisible"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/leftContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/onboard_sdk_standard_margins"
            android:paddingHorizontal="@dimen/onboard_sdk_face_match_container_horizontal_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guidelineV50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.incode.welcome_sdk.views.IncodeTextView
                android:textColor="@color/onboard_sdk_TextColorInverted"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/leftHeader"
                android:background="@drawable/onboard_sdk_selfie_result_balloon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
                style="@style/onboard_sdk_FaceMatchHeader"/>
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp">
                <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
                    android:id="@+id/leftPhoto"
                    android:background="@color/onboard_sdk_BackgroundDark"
                    android:padding="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
                    app:strokeColor="@color/onboard_sdk_BackgroundDark"
                    app:strokeWidth="2dp"/>
                <com.incode.welcome_sdk.views.IncodeTextView
                    android:textSize="90sp"
                    android:textColor="@color/onboard_sdk_TextColorInverted"
                    android:id="@+id/leftUnknown"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_sdk_questionmark"
                    android:layout_centerInParent="true"
                    app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
                    style="@style/onboard_sdk_Headline1"/>
            </RelativeLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/rightContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/onboard_sdk_standard_margins"
            android:paddingHorizontal="@dimen/onboard_sdk_face_match_container_horizontal_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guidelineV50"
            app:layout_constraintTop_toTopOf="parent">
            <com.incode.welcome_sdk.views.IncodeTextView
                android:textColor="@color/onboard_sdk_TextColorInverted"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/rightHeader"
                android:background="@drawable/onboard_sdk_selfie_result_balloon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
                style="@style/onboard_sdk_FaceMatchHeader"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp">
                <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
                    android:id="@+id/rightPhoto"
                    android:background="@color/onboard_sdk_BackgroundDark"
                    android:padding="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
                    app:strokeColor="@color/onboard_sdk_BackgroundDark"
                    app:strokeWidth="2dp"/>
                <com.incode.welcome_sdk.views.IncodeTextView
                    android:textSize="90sp"
                    android:textColor="@color/onboard_sdk_TextColorInverted"
                    android:id="@+id/rightUnknown"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_sdk_questionmark"
                    android:layout_centerInParent="true"
                    style="@style/onboard_sdk_Headline1"/>
                <ImageView
                    android:id="@+id/rightResultMark"
                    android:visibility="invisible"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerInParent="true"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/onboard_sdk_check"/>
            </RelativeLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/bottomContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/onboard_sdk_face_match_container_horizontal_padding"
            app:layout_constraintBottom_toTopOf="@+id/guidelineH93"
            app:layout_constraintEnd_toEndOf="@+id/guidelineV75"
            app:layout_constraintStart_toStartOf="@+id/guidelineV25"
            app:layout_constraintTop_toBottomOf="@+id/leftContainer">
            <com.incode.welcome_sdk.views.IncodeTextView
                android:textColor="@color/onboard_sdk_TextColorInverted"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/bottomHeader"
                android:background="@drawable/onboard_sdk_selfie_result_balloon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
                style="@style/onboard_sdk_FaceMatchHeader"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp">
                <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
                    android:id="@+id/bottomPhoto"
                    android:background="@color/onboard_sdk_BackgroundDark"
                    android:padding="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
                    app:strokeColor="@color/onboard_sdk_BackgroundDark"
                    app:strokeWidth="2dp"/>
                <com.incode.welcome_sdk.views.IncodeTextView
                    android:textSize="90sp"
                    android:textColor="@color/onboard_sdk_TextColorInverted"
                    android:id="@+id/bottomUnknown"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_sdk_questionmark"
                    android:layout_centerInParent="true"
                    style="@style/onboard_sdk_Headline1"/>
                <ImageView
                    android:id="@+id/bottomResultMark"
                    android:visibility="invisible"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerInParent="true"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/onboard_sdk_check"/>
            </RelativeLayout>
        </LinearLayout>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/guidelineV50"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.5"/>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/guidelineV25"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.25"/>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/guidelineV75"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.75"/>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@+id/guidelineH93"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.93"/>
        <androidx.constraintlayout.widget.Group
            android:id="@+id/containerUserAlreadyExists"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="userAlreadyExistsBalloon,userAlreadyExistsText"/>
        <ImageView
            android:id="@+id/userAlreadyExistsBalloon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/leftContainer"
            app:srcCompat="@drawable/onboard_sdk_balloon_user_already_exists"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textColor="@color/onboard_sdk_TextColorInverted"
            android:id="@+id/userAlreadyExistsText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/onboard_sdk_recognition_result_user_already_exists"
            android:maxLines="1"
            android:drawablePadding="10dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="40dp"
            app:drawableStartCompat="@drawable/onboard_sdk_ic_user_already_exists"
            app:layout_constraintBottom_toBottomOf="@+id/userAlreadyExistsBalloon"
            app:layout_constraintEnd_toEndOf="@+id/userAlreadyExistsBalloon"
            app:layout_constraintStart_toStartOf="@+id/userAlreadyExistsBalloon"
            app:layout_constraintTop_toTopOf="@+id/userAlreadyExistsBalloon"
            app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
            style="@style/onboard_sdk_LabelBig"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/spoofWarningContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textColor="@color/onboard_sdk_TextColorInverted"
            android:id="@+id/spoofWarning"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="12dp"
            app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
            style="@style/onboard_sdk_Headline3"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/submitOnlyState"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/onboard_sdk_check"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/progressBarContainer"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            style="@style/onboard_sdk_ProgressBarIndeterminate"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textColor="@color/onboard_sdk_TextColorDefault"
            android:id="@+id/progressText"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/onboard_sdk_processing"
            app:onboard_sdk_textColor="@color/onboard_sdk_TextColorDefault"
            style="@style/onboard_sdk_Headline2"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
