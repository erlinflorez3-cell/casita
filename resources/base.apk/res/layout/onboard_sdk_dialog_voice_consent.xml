<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/onboard_sdk_bg_tap_to_answer_layout"
    android:padding="10dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/tvVoiceConsentDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/onboard_sdk_video_selfie_voice_consent_dialog_title"
        android:includeFontPadding="false"
        android:textAlignment="textStart"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/onboard_sdk_Headline2"/>
    <ScrollView
        android:scrollbars="none"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:overScrollMode="never"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toTopOf="@+id/onboard_sdk_guideline3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvVoiceConsentDialogTitle"
        app:layout_constraintVertical_bias="0">
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/tvVoiceConsentDialogDescription"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:includeFontPadding="false"
            android:textAlignment="textStart"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            style="@style/onboard_sdk_Headline4"/>
    </ScrollView>
    <com.incode.welcome_sdk.views.IncodeButton
        android:id="@+id/btnDone"
        android:layout_width="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:text="@string/onboard_sdk_voice_consent_dialog_button_done"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintBottom_toTopOf="@+id/btnTryAgain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/onboard_sdk_guideline3"
        app:layout_constraintVertical_bias="1"
        style="@style/onboard_sdk_ButtonPrimaryMedium"/>
    <com.incode.welcome_sdk.views.IncodeButton
        android:textColor="@color/onboard_sdk_TextColorDefault"
        android:id="@+id/btnTryAgain"
        android:layout_width="0dp"
        android:layout_marginBottom="8dp"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
        style="@style/onboard_sdk_ButtonTextMedium"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@+id/onboard_sdk_guideline3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"/>
</androidx.constraintlayout.widget.ConstraintLayout>
