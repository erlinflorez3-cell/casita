<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/onboard_sdk_BackgroundLight"
        android:padding="@dimen/onboard_sdk_standard_margins"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_sdk_results_fragment_title_liveness_check"
            android:maxLines="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/onboard_sdk_Headline2"/>
        <ImageView
            android:id="@+id/ivOverallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintEnd_toStartOf="@+id/tvOverallStatus"
            app:layout_constraintTop_toTopOf="@+id/title"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textColor="@color/onboard_sdk_state_warn"
            android:id="@+id/tvOverallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAllCaps="true"
            android:paddingStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/title"
            app:onboard_sdk_textColor="@color/onboard_sdk_state_warn"
            style="@style/onboard_sdk_Headline3"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/containerLivenessCheckResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title">
            <com.incode.welcome_sdk.ui.results.common.PropertyViewBold
                android:id="@+id/pvLivenessScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:onboard_sdk_name="@string/onboard_sdk_property_liveness_score"/>
            <com.incode.welcome_sdk.ui.results.common.PropertyViewBold
                android:id="@+id/pvPhotoQuality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:onboard_sdk_name="@string/onboard_sdk_property_photo_quality"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
