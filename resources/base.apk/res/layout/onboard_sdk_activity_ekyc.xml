<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="@string/onboard_sdk_ekyc_main_title"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/onboard_sdk_Headline2"/>
    <ScrollView
        android:id="@+id/svForm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/countrySelector"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_country_form_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_country_form_title"/>
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/etFirstName"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/onboard_sdk_ekyc_name_form_hint"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_name_form_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_name_form_title"/>
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/etSurname"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/onboard_sdk_ekyc_last_name_form_hint"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_last_name_form_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_last_name_form_title"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/layoutAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.incode.welcome_sdk.views.IncodeFormItem
                    android:id="@+id/etHouseNumber"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/onboard_sdk_ekyc_house_number_form_hint"
                    app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_house_number_form_error_message"
                    app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_house_number_form_title"/>
                <com.incode.welcome_sdk.views.IncodeFormItem
                    android:id="@+id/etStreet"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/onboard_sdk_ekyc_street_form_hint"
                    app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_street_form_error_message"
                    app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_street_form_title"/>
                <com.incode.welcome_sdk.views.IncodeFormItem
                    android:id="@+id/etPostalCode"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_postal_form_error_message"
                    app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_postal_form_title"/>
                <com.incode.welcome_sdk.views.IncodeFormItem
                    android:id="@+id/etState"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/onboard_sdk_ekyc_state_form_hint"
                    app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_state_form_error_message"
                    app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_state_form_title"/>
                <com.incode.welcome_sdk.views.IncodeFormItem
                    android:id="@+id/etCity"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/onboard_sdk_ekyc_city_form_hint"
                    app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_city_form_error_message"
                    app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_city_form_title"/>
            </LinearLayout>
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/etEmail"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/onboard_sdk_ekyc_email_form_hint"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_email_form_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_email_form_title"/>
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/etPhone"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_phone_form_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_phone_form_title"/>
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/etTaxId"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_tax_id_form_us_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_tax_id_form_us_title"/>
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/dpDateOfBirth"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/onboard_sdk_ekyc_dob_form_hint"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_dob_form_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_dob_form_title"/>
            <com.incode.welcome_sdk.views.IncodeFormItem
                android:id="@+id/nationalitySelector"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:onboard_sdk_error_message="@string/onboard_sdk_ekyc_nationality_form_error_message"
                app:onboard_sdk_title_message="@string/onboard_sdk_ekyc_nationality_form_title"/>
            <com.incode.welcome_sdk.views.IncodeButton
                android:enabled="true"
                android:layout_gravity="center_horizontal"
                android:id="@+id/btnConfirm"
                android:text="@string/onboard_sdk_ekyc_btn_confirm"
                android:layout_marginStart="@dimen/onboard_sdk_btn_margins"
                android:layout_marginEnd="@dimen/onboard_sdk_btn_margins"
                android:layout_marginVertical="40dp"
                style="@style/onboard_sdk_ButtonPrimaryBig"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/loading_layout"
        android:background="@android:color/white"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/txtSigning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:text="@string/onboard_sdk_ekyc_loading_message"
            style="@style/onboard_sdk_Headline2"/>
        <ProgressBar
            android:layout_gravity="center"
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            style="@style/onboard_sdk_ProgressBarIndeterminate"/>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/success_layout"
        android:background="@android:color/white"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/imgSuccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/onboard_sdk_ic_success"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/txtEKYCSuccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/onboard_sdk_ekyc_success_message"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imgSuccess"
            style="@style/onboard_sdk_Headline2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/fail_layout"
        android:background="@android:color/white"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/imgFail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/onboard_sdk_ic_failure"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/txtEKYCFail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/onboard_sdk_ekyc_fail_message"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imgFail"
            style="@style/onboard_sdk_Headline2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
