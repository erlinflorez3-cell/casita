<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/progressContainer"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ProgressBar
            android:id="@+id/pb_preparing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:layout_marginEnd="10dp"
            style="@style/onboard_sdk_ProgressBarIndeterminate"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_sdk_results_fetching_in_progress"
            style="@style/onboard_sdk_Headline2"/>
    </LinearLayout>
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:gravity="center_horizontal"
            android:id="@+id/appBarLayout"
            android:background="@color/onboard_sdk_white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/onboard_sdk_results_activity_app_bar_height"
            app:elevation="0dp">
            <View
                android:layout_width="wrap_content"
                android:layout_height="108dp"
                app:layout_scrollFlags="scroll"/>
            <View
                android:layout_width="wrap_content"
                android:layout_height="59dp"/>
            <com.incode.welcome_sdk.ui.results.common.PersistentIconsTabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:tabIndicatorColor="@color/onboard_sdk_IconColorDefault"
                app:tabIndicatorFullWidth="true"
                app:tabIndicatorHeight="4dp"/>
        </com.google.android.material.appbar.AppBarLayout>
        <androidx.viewpager.widget.ViewPager
            android:id="@+id/viewPager"
            android:paddingBottom="@dimen/onboard_sdk_results_activity_app_bar_height"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        <FrameLayout
            android:layout_gravity="top|center_horizontal"
            android:id="@+id/containerAvatar"
            android:paddingTop="36dp"
            android:clipToPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_behavior="com.incode.welcome_sdk.ui.results.common.ScrollingAlphaBehaviour">
            <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
                android:layout_gravity="center_horizontal"
                android:id="@+id/ivAvatar"
                android:background="@color/onboard_sdk_BackgroundDark"
                android:padding="1dp"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
                app:srcCompat="@drawable/onboard_sdk_placeholder_face"
                app:strokeColor="@color/onboard_sdk_BackgroundDark"
                app:strokeWidth="1dp"/>
            <ImageView
                android:layout_gravity="bottom|center_horizontal"
                android:id="@+id/ivAvatarStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_anchor="@+id/ivAvatar"
                app:layout_anchorGravity="bottom|center_horizontal"/>
        </FrameLayout>
        <com.incode.welcome_sdk.views.IncodeButton
            android:layout_gravity="top|right"
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginRight="20dp"
            android:text="@string/onboard_sdk_results_btn_done"
            style="@style/onboard_sdk_ButtonTextSmall"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_behavior="com.incode.welcome_sdk.ui.results.common.ScrollingNameScoreBehaviour">
            <com.incode.welcome_sdk.ui.results.common.TextViewName
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/onboard_sdk_standard_margins"
                android:layout_marginTop="106dp"
                android:layout_marginRight="@dimen/onboard_sdk_standard_margins"
                style="@style/onboard_sdk_Headline3"/>
            <com.incode.welcome_sdk.views.IncodeTextView
                android:textColor="@color/onboard_sdk_state_success"
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:onboard_sdk_textColor="@color/onboard_sdk_state_success"
                style="@style/onboard_sdk_Headline4"/>
        </LinearLayout>
        <com.incode.welcome_sdk.views.IncodeButton
            android:layout_gravity="top|left"
            android:id="@+id/btnReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="28dp"
            android:text="@string/onboard_sdk_btn_reports"
            style="@style/onboard_sdk_ButtonPrimarySmall"/>
        <View
            android:layout_width="wrap_content"
            android:layout_height="108dp"
            app:layout_anchor="@+id/appBarLayout"
            app:layout_anchorGravity="center"
            app:layout_scrollFlags="scroll"/>
        <View
            android:layout_width="wrap_content"
            android:layout_height="59dp"
            app:layout_anchor="@+id/appBarLayout"
            app:layout_anchorGravity="center"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>
