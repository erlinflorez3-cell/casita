<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?android:attr/windowBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/ivInterviewerAvatar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginStart="18dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/onboard_sdk_interviewer_avatar"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:gravity="start"
        android:id="@+id/tvInterviewerName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ivInterviewerAvatar"
        app:layout_constraintTop_toTopOf="@+id/ivInterviewerAvatar"
        style="@style/onboard_sdk_Headline3"/>
    <View
        android:id="@+id/onlineIndicator"
        android:background="@drawable/onboard_sdk_chat_online_indicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/ivInterviewerAvatar"
        app:layout_constraintStart_toStartOf="@+id/tvInterviewerName"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:textColor="@color/onboard_sdk_TextColorLabel"
        android:id="@+id/txtOnlineIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginBottom="2dp"
        android:text="@string/onboard_sdk_conference_interviewer_connected"
        app:layout_constraintBottom_toBottomOf="@+id/onlineIndicator"
        app:layout_constraintStart_toEndOf="@+id/onlineIndicator"
        app:layout_constraintTop_toTopOf="@+id/onlineIndicator"
        app:onboard_sdk_textColor="@color/onboard_sdk_TextColorLabel"
        style="@style/onboard_sdk_LabelSmall"/>
    <com.incode.welcome_sdk.views.IncodeDividerView
        android:id="@+id/dividerTop"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivInterviewerAvatar"
        style="@style/onboard_sdk_Divider"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/dividerBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dividerTop"
        app:layout_constraintVertical_bias="0"/>
    <com.incode.welcome_sdk.views.IncodeDividerView
        android:id="@+id/dividerBottom"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@+id/etChat"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/onboard_sdk_Divider"/>
    <com.incode.welcome_sdk.views.IncodeEditText
        android:gravity="start"
        android:id="@+id/etChat"
        android:background="@null"
        android:padding="18dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/onboard_sdk_chat_hint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnSend"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/onboard_sdk_InputSmall"/>
    <com.incode.welcome_sdk.views.IncodeButton
        android:enabled="false"
        android:id="@+id/btnSend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/onboard_sdk_conference_chat_send"
        app:layout_constraintBottom_toBottomOf="@+id/etChat"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etChat"
        style="@style/onboard_sdk_ButtonTextSmall"/>
</androidx.constraintlayout.widget.ConstraintLayout>
