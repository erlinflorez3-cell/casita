<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/aesUploadContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/aesUploadTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/onboard_sdk_aes_upload_screen_title"
        android:textAlignment="textStart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/onboard_sdk_Headline2"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/aesUploadSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/onboard_sdk_aes_upload_screen_subtitle"
        android:textAlignment="textStart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aesUploadTitle"
        style="@style/onboard_sdk_Headline4"/>
    <com.incode.welcome_sdk.views.IncodeDividerView
        android:id="@+id/aesUploadDivider1"
        android:layout_marginTop="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aesUploadSubtitle"
        style="@style/onboard_sdk_Divider"/>
    <ImageView
        android:id="@+id/aesUploadDocumentIcon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/onboard_sdk_aes_ic_files"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/aesUploadDivider2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aesUploadDivider1"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/aesUploadContractNameTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/onboard_sdk_aes_upload_screen_empty_label"
        android:layout_marginStart="4dp"
        app:layout_constraintBottom_toTopOf="@+id/aesUploadDivider2"
        app:layout_constraintStart_toEndOf="@+id/aesUploadDocumentIcon"
        app:layout_constraintTop_toBottomOf="@+id/aesUploadDivider1"
        style="@style/onboard_sdk_LabelBig"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/aesUploadAddDocTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/aesUploadDivider2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aesUploadDivider1"
        style="@style/onboard_sdk_LabelBig"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:textColor="@color/onboard_sdk_state_destructive"
        android:id="@+id/aesUploadRemoveDocTv"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/aesUploadDivider2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aesUploadDivider1"
        style="@style/onboard_sdk_LabelBig"/>
    <com.incode.welcome_sdk.views.IncodeDividerView
        android:id="@+id/aesUploadDivider2"
        android:layout_marginTop="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aesUploadDivider1"
        style="@style/onboard_sdk_Divider"/>
    <com.incode.welcome_sdk.views.IncodeButton
        android:id="@+id/aesUploadContinueBtn"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="60dp"
        android:text="@string/onboard_sdk_aes_btn_continue"
        android:layout_marginStart="@dimen/onboard_sdk_btn_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_btn_margins"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        style="@style/onboard_sdk_ButtonPrimaryBig"/>
</androidx.constraintlayout.widget.ConstraintLayout>
