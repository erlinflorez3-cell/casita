<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/onboard_sdk_BackgroundLight"
        android:padding="@dimen/onboard_sdk_standard_margins"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_sdk_results_fragment_title_facial_recognition"
            android:maxLines="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/onboard_sdk_Headline2"/>
        <ImageView
            android:id="@+id/ivOverallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintEnd_toStartOf="@+id/tvOverallStatus"
            app:layout_constraintTop_toTopOf="@+id/title"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textColor="@color/onboard_sdk_state_destructive"
            android:id="@+id/tvOverallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAllCaps="true"
            android:paddingStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/title"
            app:onboard_sdk_textColor="@color/onboard_sdk_state_destructive"
            style="@style/onboard_sdk_Headline3"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/tvLabelSelfie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/onboard_sdk_facial_recognition_label_selfie"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="@+id/ivSelfie"
            app:layout_constraintStart_toStartOf="@+id/ivSelfie"
            app:layout_constraintTop_toBottomOf="@+id/title"
            style="@style/onboard_sdk_LabelBig"/>
        <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
            android:id="@+id/ivSelfie"
            android:background="@color/onboard_sdk_BackgroundDark"
            android:padding="3dp"
            android:layout_width="101dp"
            android:layout_height="101dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toStartOf="@+id/ivIdPhoto"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelSelfie"
            app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
            app:srcCompat="@drawable/onboard_sdk_placeholder_face"
            app:strokeColor="@color/onboard_sdk_white"
            app:strokeWidth="3dp"/>
        <View
            android:id="@+id/verticalLine1"
            android:background="@color/onboard_sdk_BackgroundDark"
            android:layout_width="2dp"
            android:layout_height="9dp"
            android:layout_marginTop="8dp"
            android:alpha="0.1"
            app:layout_constraintEnd_toEndOf="@+id/ivSelfie"
            app:layout_constraintStart_toStartOf="@+id/ivSelfie"
            app:layout_constraintTop_toBottomOf="@+id/ivSelfie"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/tvLabelIdPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_sdk_facial_recognition_label_id"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="@+id/ivIdPhoto"
            app:layout_constraintStart_toStartOf="@+id/ivIdPhoto"
            app:layout_constraintTop_toTopOf="@+id/tvLabelSelfie"
            style="@style/onboard_sdk_LabelBig"/>
        <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
            android:id="@+id/ivIdPhoto"
            android:background="@color/onboard_sdk_BackgroundDark"
            android:padding="3dp"
            android:layout_width="101dp"
            android:layout_height="101dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/ivSelfie"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelIdPhoto"
            app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
            app:strokeColor="@color/onboard_sdk_white"
            app:strokeWidth="3dp"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textSize="70sp"
            android:textColor="@color/onboard_sdk_TextColorInverted"
            android:id="@+id/txtCardUnknown"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            app:layout_constraintBottom_toBottomOf="@+id/ivIdPhoto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/ivSelfie"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelIdPhoto"
            style="@style/onboard_sdk_Headline1"/>
        <View
            android:id="@+id/verticalLine2"
            android:background="@color/onboard_sdk_BackgroundDark"
            android:layout_width="2dp"
            android:layout_height="9dp"
            android:layout_marginTop="8dp"
            android:alpha="0.1"
            app:layout_constraintEnd_toEndOf="@+id/ivIdPhoto"
            app:layout_constraintStart_toStartOf="@+id/ivIdPhoto"
            app:layout_constraintTop_toBottomOf="@+id/ivIdPhoto"/>
        <View
            android:id="@+id/horizontalLine"
            android:background="@color/onboard_sdk_BackgroundDark"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:alpha="0.1"
            app:layout_constraintEnd_toStartOf="@+id/verticalLine2"
            app:layout_constraintStart_toEndOf="@+id/verticalLine1"
            app:layout_constraintTop_toBottomOf="@+id/verticalLine1"/>
        <View
            android:id="@+id/corner1"
            android:background="@color/onboard_sdk_BackgroundDark"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:alpha="0.1"
            app:layout_constraintEnd_toStartOf="@+id/horizontalLine"
            app:layout_constraintTop_toBottomOf="@+id/verticalLine1"/>
        <View
            android:id="@+id/corner2"
            android:background="@color/onboard_sdk_BackgroundDark"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:alpha="0.1"
            app:layout_constraintStart_toEndOf="@+id/horizontalLine"
            app:layout_constraintTop_toBottomOf="@+id/verticalLine2"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/tvLabelMatchingResults"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="@+id/horizontalLine"
            app:layout_constraintStart_toStartOf="@+id/horizontalLine"
            app:layout_constraintTop_toBottomOf="@+id/horizontalLine"
            style="@style/onboard_sdk_LabelBig"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/containerFacialRecognitionResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelMatchingResults">
            <com.incode.welcome_sdk.ui.results.common.PropertyViewBold
                android:id="@+id/pvUserAlreadyInDatabase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:onboard_sdk_name="@string/onboard_sdk_property_user_already_in_database"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
