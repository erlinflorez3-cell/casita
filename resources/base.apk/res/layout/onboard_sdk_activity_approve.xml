<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.incode.welcome_sdk.views.IncodeTextView
        android:id="@+id/tvMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/onboard_sdk_Headline1"/>
    <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
        android:id="@+id/ivSelfie"
        android:background="@color/onboard_sdk_BackgroundDark"
        android:padding="2dp"
        android:layout_width="180dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="H,1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
        app:strokeColor="@color/onboard_sdk_BackgroundDark"
        app:strokeWidth="2dp"/>
    <com.incode.welcome_sdk.commons.ui.RoundedCornersFixedWidthSquareImage
        android:id="@+id/ivStateContainer"
        android:background="@color/onboard_sdk_state_success"
        android:padding="2dp"
        android:visibility="invisible"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="center"
        app:layout_constraintBottom_toBottomOf="@+id/ivSelfie"
        app:layout_constraintEnd_toEndOf="@+id/ivSelfie"
        app:layout_constraintStart_toStartOf="@+id/ivSelfie"
        app:layout_constraintTop_toTopOf="@+id/ivSelfie"
        app:shapeAppearanceOverlay="@style/onboard_sdk_CircleImageViewShape"
        app:strokeColor="@color/onboard_sdk_BackgroundDark"
        app:strokeWidth="2dp"/>
    <ImageView
        android:id="@+id/ivState"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/ivSelfie"
        app:layout_constraintEnd_toEndOf="@+id/ivSelfie"
        app:layout_constraintStart_toStartOf="@+id/ivSelfie"
        app:layout_constraintTop_toTopOf="@+id/ivSelfie"
        app:srcCompat="@drawable/onboard_sdk_check"/>
    <com.incode.welcome_sdk.views.IncodeButton
        android:id="@+id/btnTryAgain"
        android:visibility="invisible"
        android:layout_marginBottom="70dp"
        android:text="@string/onboard_sdk_try_again"
        android:layout_marginStart="@dimen/onboard_sdk_btn_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_btn_margins"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/onboard_sdk_ButtonPrimaryBig"/>
</androidx.constraintlayout.widget.ConstraintLayout>
