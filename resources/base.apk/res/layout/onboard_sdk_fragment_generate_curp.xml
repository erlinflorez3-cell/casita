<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    app:layout_constraintBottom_toTopOf="@+id/btnContinue"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="@string/onboard_sdk_curp_generate_title"
            android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/onboard_sdk_Headline2"/>
        <com.incode.welcome_sdk.views.IncodeEditText
            android:gravity="center"
            android:id="@+id/editTextName"
            android:layout_width="0dp"
            android:layout_marginTop="60dp"
            android:hint="@string/onboard_sdk_curp_first_name"
            android:maxLines="1"
            android:inputType="textCapWords"
            android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle"
            style="@style/onboard_sdk_InputEditText"/>
        <com.incode.welcome_sdk.views.IncodeEditText
            android:gravity="center"
            android:id="@+id/editTextFirstLastName"
            android:layout_width="0dp"
            android:layout_marginTop="12dp"
            android:hint="@string/onboard_sdk_curp_first_last_name"
            android:maxLines="1"
            android:inputType="textCapWords"
            android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editTextName"
            style="@style/onboard_sdk_InputEditText"/>
        <com.incode.welcome_sdk.views.IncodeEditText
            android:gravity="center"
            android:id="@+id/editTextSecondLastName"
            android:layout_width="0dp"
            android:layout_marginTop="12dp"
            android:hint="@string/onboard_sdk_curp_second_last_name"
            android:maxLines="1"
            android:inputType="textCapWords"
            android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editTextFirstLastName"
            style="@style/onboard_sdk_InputEditText"/>
        <com.incode.welcome_sdk.views.IncodeSpinner
            android:gravity="center"
            android:id="@+id/dropDownGender"
            android:layout_width="0dp"
            android:layout_marginTop="12dp"
            android:hint="@string/onboard_sdk_curp_gender"
            android:maxLines="1"
            android:dropDownSelector="@android:color/transparent"
            android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editTextSecondLastName"
            style="@style/onboard_sdk_InputEditText"/>
        <ImageView
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:layout_marginEnd="24dp"
            app:layout_constraintBottom_toBottomOf="@+id/dropDownGender"
            app:layout_constraintEnd_toEndOf="@+id/dropDownGender"
            app:layout_constraintTop_toTopOf="@+id/dropDownGender"
            app:srcCompat="@drawable/onboard_sdk_ic_drop_down"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:gravity="center"
            android:id="@+id/textViewBirthDate"
            android:layout_width="0dp"
            android:layout_marginTop="12dp"
            android:hint="@string/onboard_sdk_curp_birth_date"
            android:maxLines="1"
            android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/dropDownGender"
            style="@style/onboard_sdk_InputEditText"/>
        <ImageView
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:layout_marginEnd="20dp"
            app:layout_constraintBottom_toBottomOf="@+id/textViewBirthDate"
            app:layout_constraintEnd_toEndOf="@+id/textViewBirthDate"
            app:layout_constraintTop_toTopOf="@+id/textViewBirthDate"
            app:srcCompat="@drawable/onboard_sdk_ic_calendar"/>
        <com.incode.welcome_sdk.views.IncodeSpinner
            android:gravity="center"
            android:id="@+id/dropDownState"
            android:layout_width="0dp"
            android:layout_marginTop="12dp"
            android:hint="@string/onboard_sdk_curp_state"
            android:maxLines="1"
            android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textViewBirthDate"
            style="@style/onboard_sdk_InputEditText"/>
        <ImageView
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:layout_marginEnd="24dp"
            app:layout_constraintBottom_toBottomOf="@+id/dropDownState"
            app:layout_constraintEnd_toEndOf="@+id/dropDownState"
            app:layout_constraintTop_toTopOf="@+id/dropDownState"
            app:srcCompat="@drawable/onboard_sdk_ic_drop_down"/>
        <com.incode.welcome_sdk.views.IncodeButton
            android:enabled="false"
            android:id="@+id/btnContinue"
            android:layout_marginTop="52dp"
            android:layout_marginBottom="60dp"
            android:text="@string/onboard_sdk_btn_generate"
            android:layout_marginStart="@dimen/onboard_sdk_btn_margins"
            android:layout_marginEnd="@dimen/onboard_sdk_btn_margins"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/dropDownState"
            style="@style/onboard_sdk_ButtonPrimaryBig"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
