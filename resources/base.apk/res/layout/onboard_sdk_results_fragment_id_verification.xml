<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/onboard_sdk_BackgroundLight"
        android:padding="@dimen/onboard_sdk_standard_margins"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.incode.welcome_sdk.views.IncodeTextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_sdk_results_fragment_title_id_verification"
            android:maxLines="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/onboard_sdk_Headline2"/>
        <ImageView
            android:id="@+id/ivOverallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintEnd_toStartOf="@+id/tvOverallStatus"
            app:layout_constraintTop_toTopOf="@+id/title"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textColor="@color/onboard_sdk_state_success"
            android:id="@+id/tvOverallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAllCaps="true"
            android:paddingStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/title"
            app:onboard_sdk_textColor="@color/onboard_sdk_state_success"
            style="@style/onboard_sdk_Headline3"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:textColor="@color/onboard_sdk_state_destructive"
            android:id="@+id/tvManualCheckNeeded"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/onboard_sdk_id_verification_manual_check_needed"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:onboard_sdk_textColor="@color/onboard_sdk_state_destructive"
            style="@style/onboard_sdk_Headline2"/>
        <ImageView
            android:id="@+id/ivIdFront"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:adjustViewBounds="true"
            android:maxHeight="150dp"
            android:layout_marginEnd="8dp"
            app:elevation="10dp"
            app:layout_constraintEnd_toStartOf="@+id/guidelineV50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title"
            app:srcCompat="@drawable/onboard_sdk_placeholder_id_front"/>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/guidelineV50"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            app:layout_constraintGuide_percent="0.5"/>
        <ImageView
            android:id="@+id/ivIdBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:maxHeight="150dp"
            android:layout_marginStart="8dp"
            app:elevation="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/ivIdFront"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guidelineV50"
            app:layout_constraintTop_toTopOf="@+id/ivIdFront"
            app:srcCompat="@drawable/onboard_sdk_placeholder_id_back"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:gravity="start"
            android:id="@+id/tvTitlePhotoSecurityAndQuality"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/onboard_sdk_section_title_photo_security_and_quality"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivIdFront"
            style="@style/onboard_sdk_Headline3"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/containerPhotoSecurityAndQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitlePhotoSecurityAndQuality"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:gravity="start"
            android:id="@+id/tvTitleIdSpecific"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/onboard_sdk_section_title_id_specific"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/containerPhotoSecurityAndQuality"
            style="@style/onboard_sdk_Headline3"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/containerIdSpecific"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitleIdSpecific"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
