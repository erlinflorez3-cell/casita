<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/rounded_border_white"
    android:layout_width="280dp"
    android:layout_height="300dp"
    android:layout_centerHorizontal="true">
    <ImageView
        android:id="@+id/imageViewAlert"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:flow_horizontalAlign="center"
        app:flow_verticalAlign="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.065"
        app:srcCompat="@drawable/ic_alerta_admiracion_rojo"/>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:id="@+id/TitleAlert"
        android:layout_width="232dp"
        android:layout_height="40dp"
        android:text="@string/AlertTitle"
        android:textAlignment="center"
        android:layout_marginVertical="8dp"
        android:lineHeight="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.319"/>
    <TextView
        android:textSize="12sp"
        android:id="@+id/DescriptionAlert"
        android:layout_width="232dp"
        android:layout_height="wrap_content"
        android:text="@string/AlertDescription"
        android:textAlignment="center"
        android:layout_marginVertical="8dp"
        android:lineHeight="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.618"/>
    <Button
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:id="@+id/AlertButton"
        android:background="@drawable/rounded_border_red"
        android:layout_width="144dp"
        android:layout_height="40dp"
        android:text="@string/AlertButton"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:layout_marginVertical="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.984"/>
</androidx.constraintlayout.widget.ConstraintLayout>
