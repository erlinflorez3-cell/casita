<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.incode.welcome_sdk.commons.ui.VignetteView
            android:id="@+id/vignette"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <com.incode.welcome_sdk.commons.ui.FlashingBorderView
            android:id="@+id/vignetteFlashingBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <View
            android:id="@+id/scanWindowBackground"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <View
            android:id="@+id/scanWindowOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <com.incode.welcome_sdk.views.IncodeTextView
            android:layout_gravity="center"
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/onboard_sdk_Headline2"/>
    </FrameLayout>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:textColor="@color/onboard_sdk_TextColorInverted"
        android:id="@+id/feedbackTopMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="@string/onboard_sdk_qr_scan_feedback_top"
        android:layout_marginStart="@dimen/onboard_sdk_standard_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:onboard_sdk_textColor="@color/onboard_sdk_TextColorInverted"
        style="@style/onboard_sdk_Headline2"/>
    <ImageView
        android:id="@+id/btnClose"
        android:padding="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/onboard_sdk_standard_margins"
        app:layout_constraintBottom_toTopOf="@+id/feedbackTopMessage"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/onboard_sdk_close_button_inverted"/>
    <com.incode.welcome_sdk.views.IncodeButton
        android:id="@+id/btnNeedHelp"
        android:text="@string/onboard_sdk_qr_scan_help_btn"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/onboard_sdk_ButtonNeedHelp"/>
    <FrameLayout
        android:id="@+id/modalScreensContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            layout="@layout/onboard_sdk_qr_scan_help_screen"/>
    </FrameLayout>
    <com.incode.welcome_sdk.views.IncodeButton
        android:id="@+id/btnTryAgain"
        android:visibility="invisible"
        android:layout_marginBottom="48dp"
        android:text="@string/onboard_sdk_validation_btn_try_again"
        android:layout_marginStart="@dimen/onboard_sdk_btn_margins"
        android:layout_marginEnd="@dimen/onboard_sdk_btn_margins"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/onboard_sdk_ButtonPrimaryBig"/>
</androidx.constraintlayout.widget.ConstraintLayout>
