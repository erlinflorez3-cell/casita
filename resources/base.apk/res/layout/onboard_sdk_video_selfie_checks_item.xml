<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.incode.welcome_sdk.views.IncodeImageView
        android:id="@+id/ivVsChecksIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/viewConnectorBottom"
        android:background="@color/onboard_sdk_BackgroundLight"
        android:layout_width="2dp"
        android:layout_height="6dp"
        app:layout_constraintEnd_toEndOf="@+id/ivVsChecksIcon"
        app:layout_constraintStart_toStartOf="@+id/ivVsChecksIcon"
        app:layout_constraintTop_toBottomOf="@+id/ivVsChecksIcon"/>
    <com.incode.welcome_sdk.views.IncodeTextView
        android:gravity="start"
        android:id="@+id/tvVsChecksItemTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/ivVsChecksIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/ivVsChecksIcon"
        app:layout_constraintTop_toTopOf="@+id/ivVsChecksIcon"
        style="@style/onboard_sdk_Headline4"/>
</androidx.constraintlayout.widget.ConstraintLayout>
